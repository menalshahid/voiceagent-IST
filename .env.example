# Copy to .env and fill in your values

# Groq (required for RAG + STT). One key or comma-separated list:
GROQ_API_KEY=your_groq_api_key_here
# OR for multiple keys: GROQ_API_KEYS=key1,key2,key3

# LiveKit (required for voice/call). Get from https://cloud.livekit.io
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Optional: enable Flask debug when running locally
# FLASK_ENV=development
